SECRET_KEY=customer-secret-change-me
JWT_SECRET_KEY=customer-jwt-secret-change-me
FLASK_ENV=development
PORTAL_ROLE=customer
PORT=5000

DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=replace-with-your-tidb-user
DB_PASSWORD=replace-with-your-tidb-password
DB_NAME=bakerydb
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=true

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

CUSTOMER_PORTAL_URL=http://127.0.0.1:5000
BOOTSTRAP_SEED_DATA=false
SHOW_DEMO_ACCOUNTS=false
