# SweetCrumbs Bakery — shared environment template
# Copy to .env (root) or portal-specific .env under admin_app/ / delivery_app/ / customer_app/

SECRET_KEY=change-this-to-a-long-random-secret-key
JWT_SECRET_KEY=change-this-to-a-long-random-jwt-secret
FLASK_ENV=development
PORTAL_ROLE=customer

# --- Database (TiDB Cloud / MySQL) ---
# Option 1: full SQLAlchemy URL
# DATABASE_URL=mysql+pymysql://user:pass@gateway.host:4000/bakerydb

# Option 2: individual variables (used by Render blueprint)
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=replace-with-your-tidb-user
DB_PASSWORD=replace-with-your-tidb-password
DB_NAME=bakerydb
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=true

# --- Redis (required in production) ---
REDIS_URL=redis://127.0.0.1:6379/0
SOCKETIO_MESSAGE_QUEUE=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# --- Cloudinary (required in production) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=bakery/products

# --- Portal URLs (production CORS / SocketIO) ---
CUSTOMER_PORTAL_URL=https://your-customer-app.onrender.com
ADMIN_PORTAL_URL=http://127.0.0.1:5001
DELIVERY_PORTAL_URL=http://127.0.0.1:5002

# --- Offline sync (admin / delivery local portals) ---
OFFLINE_SYNC_ENABLED=true

# --- Optional integrations ---
# WHATSAPP_ENABLED=false
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# GOOGLE_MAPS_API_KEY=
# FCM_ENABLED=false
# FIREBASE_CREDENTIALS_JSON=
# SENTRY_DSN=

# --- Deploy / bootstrap ---
BOOTSTRAP_SEED_DATA=false
SHOW_DEMO_ACCOUNTS=false
AUTO_INIT_DB=false
