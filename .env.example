# ─── SweetCrumbs Bakery — Environment Variables ───
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-this-to-a-long-random-secret-key
FLASK_ENV=development

# MySQL — update with your credentials
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost/bakery_db

# Optional: set to 'production' for live deployment
# FLASK_ENV=production

# Optional footer links (leave blank to hide Instagram / Facebook icons)
# BAKERY_INSTAGRAM_URL=https://instagram.com/yourbakery
# BAKERY_FACEBOOK_URL=https://facebook.com/yourbakery
