SECRET_KEY=admin-secret-change-me
JWT_SECRET_KEY=admin-jwt-secret-change-me
FLASK_ENV=development
PORTAL_ROLE=admin
PORT=5001

DATABASE_URL=mysql+pymysql://replace-user:replace-password@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/bakerydb
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
DB_SSL_VERIFY_CERT=true
DB_SSL_VERIFY_IDENTITY=true

REDIS_URL=redis://127.0.0.1:6379/0
SOCKETIO_MESSAGE_QUEUE=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
OFFLINE_SYNC_ENABLED=true
ADMIN_PORTAL_URL=http://127.0.0.1:5001
CUSTOMER_PORTAL_URL=http://127.0.0.1:5000
DELIVERY_PORTAL_URL=http://127.0.0.1:5002

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
